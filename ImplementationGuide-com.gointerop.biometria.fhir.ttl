       ] ;
       fhir:name [ fhir:v "Atendimento com Autenticação Biométrica" ] ;
       fhir:description [ fhir:v "Atendimento de saúde onde o beneficiário foi autenticado via biometria facial no início. Vincula a autenticação biométrica ao atendimento real. Cobre os Casos de Uso 2, 3 e 4 da norma ANS v5." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
